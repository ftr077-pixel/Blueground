# Environment variables for the Rental Orchestrator Hub.
# Copy to .env.local (gitignored) and fill in real values — NEVER commit secrets.
# On the box, setup-box.sh writes these into /opt/rohub/.env.local for the
# systemd service. Restart the app after changing them (systemctl restart rohub).

# --- Dashboard login (optional HTTP basic auth, works without a domain) -------
DASHBOARD_USER=
DASHBOARD_PASS=

# --- Airbnb visibility scraper -----------------------------------------------
# Shared secret between the app and run_agent.py (auto-generated by setup-box.sh).
SCRAPER_API_KEY=
# Residential proxy for the scraper (datacenter IPs get blocked by Airbnb).
PROXY_URL=

# --- External market data (AirROI) -------------------------------------------
# Get a key at https://www.airroi.com/developer . When set, the pricing engine
# uses live AirROI market data and the daily market-sync cron is enabled.
AIRROI_API_KEY=
# Region appended when resolving each neighborhood to an AirROI market.
AIRROI_REGION_HINT=Tel Aviv-Yafo, Israel
# Optional: base URL override (defaults to https://api.airroi.com).
# AIRROI_BASE_URL=https://api.airroi.com
# Optional: skip a market sync if one ran within this many hours (default 6).
# MARKET_SYNC_MIN_HOURS=6
# Optional: currency AirROI returns ('native' = the market's local currency, or 'usd').
# AIRROI_CURRENCY=native
# Optional: currency label shown on cached market data (display only).
# AIRROI_DISPLAY_CURRENCY=ILS

# --- Misc ---------------------------------------------------------------------
# Optional: where the scraper lives, for the dashboard "Run scan now" button
# (defaults to <app dir>/scraper).
# SCRAPER_DIR=/opt/rohub/scraper
