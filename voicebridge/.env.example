# Публичный хост, куда Twilio шлёт webhook и WS (без схемы)
PUBLIC_HOST=voice.example.com

# Twilio — только для валидации подписи webhook (опционально, но рекомендуется)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Локальный vLLM (OpenAI-compatible)
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_MODEL=Qwen/Qwen3-8B-AWQ
